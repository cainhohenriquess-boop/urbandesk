# ─────────────────────────────────────────────
# UrbanDesk — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha
# NUNCA commite o .env.local com valores reais
# ─────────────────────────────────────────────

# ── Banco de Dados ──────────────────────────
# PostgreSQL com extensão PostGIS
DATABASE_URL="postgresql://postgres.rglrgnaprvmtzjvdxbrd:pzy7rctCk9h%3F_3G@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── NextAuth.js ─────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="chave-secreta-urbandesk-producao-2026"
NEXTAUTH_URL="http://localhost:3000"

# ── Mapbox ──────────────────────────────────
# Token público (prefixo pk.)
NEXT_PUBLIC_MAPBOX_TOKEN="pk.your-mapbox-token-here"

# ── App ─────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# -- Storage --
# Driver: local (default) ou s3
STORAGE_DRIVER="local"

# S3 / R2 (obrigatorio se STORAGE_DRIVER=s3)
S3_REGION="auto"
S3_BUCKET="urbandesk-media"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
S3_PUBLIC_BASE_URL=""
S3_FORCE_PATH_STYLE="false"
S3_SIGNED_URL_TTL_SECONDS="900"

# Compatibilidade legada com Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ── E-mail (Resend) ─────────────────────────
RESEND_API_KEY="re_your-resend-key"
EMAIL_FROM="UrbanDesk <noreply@urbandesk.com.br>"
