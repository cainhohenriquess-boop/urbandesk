# UrbanDesk - Environment template
# Copy to .env.local (development) or configure in your deploy platform.
# Never commit real secrets.

# Runtime
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# Map
NEXT_PUBLIC_MAPBOX_TOKEN="pk.REPLACE_WITH_PUBLIC_MAPBOX_TOKEN"

# Storage
# STORAGE_DRIVER: local | s3
STORAGE_DRIVER="local"

# S3 / R2 settings (required when STORAGE_DRIVER=s3)
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
S3_PUBLIC_BASE_URL=""
S3_FORCE_PATH_STYLE="false"
S3_SIGNED_URL_TTL_SECONDS="900"

# Legacy R2 aliases (optional)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="UrbanDesk <noreply@example.com>"
