// ─────────────────────────────────────────────
// UrbanDesk — Prisma Schema
// Banco: PostgreSQL + PostGIS
// ─────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL") // <-- ADICIONE ESTA LINHA
  extensions = [postgis]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum TenantStatus {
  TRIAL
  ATIVO
  INADIMPLENTE
  CANCELADO
}

enum TenantPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  SUPERADMIN
  SECRETARIO
  ENGENHEIRO
  CAMPO
}

enum ProjectStatus {
  PLANEJADO
  EM_ANDAMENTO
  PARALISADO
  CONCLUIDO
  CANCELADO
}

enum AssetType {
  PONTO   
  TRECHO      
  AREA        
}

enum InvoiceStatus {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

// ─────────────────────────────────────────────
// TENANT (Prefeitura / Município)
// ─────────────────────────────────────────────
model Tenant {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  cnpj         String       @unique
  state        String       @db.Char(2)
  plan         TenantPlan   @default(STARTER)
  status       TenantStatus @default(TRIAL)
  mrr          Decimal      @default(0)         @db.Decimal(12, 2)
  trialEndsAt  DateTime?
  logoUrl      String?

  // NOVO: Centro geográfico do município para o mapa voar (FlyTo)
  mapLat       Float?       // Ex: -3.7319 (Fortaleza)
  mapLng       Float?       // Ex: -38.5267
  mapZoom      Float?       @default(12)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users        User[]
  projects     Project[]
  assets       Asset[]
  invoices     Invoice[]
  baseLayers   BaseLayer[]  // Shapefiles da Prefeitura

  @@map("tenants")
}

// NOVO: Tabela para armazenar os Shapefiles (Ruas e Limites) do SuperAdmin
model BaseLayer {
  id          String   @id @default(cuid())
  name        String   // Ex: "Malha Viária Centro" ou "Limite Municipal"
  type        String   // Ex: "STREETS", "BOUNDARY"
  geoJsonData Json     // O shapefile convertido armazenado de forma hiper-rápida para o frontend ler
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@map("base_layers")
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CAMPO)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assetLogs    AssetLog[]
  sessions     UserSession[]

  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────
// PROJECT (Obra / Intervenção / Área de Projeto)
// ─────────────────────────────────────────────
model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  status       ProjectStatus @default(PLANEJADO)
  budget       Decimal?      @db.Decimal(15, 2)
  startDate    DateTime?
  endDate      DateTime?
  completionPct Int          @default(0)

  // NOVO: Polígono que delimita onde os técnicos podem operar
  geomWkt      String?       // Polígono do Loteamento/Área

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  assets       Asset[]

  @@index([tenantId])
  @@index([status])
  @@map("projects")
}

// ─────────────────────────────────────────────
// ASSET (Ativos Projetados: Tubulações, Bocas de Lobo, etc)
// ─────────────────────────────────────────────
model Asset {
  id           String    @id @default(cuid())
  name         String
  type         AssetType
  description  String?
  photos       String[]  
  
  // AQUI É A MÁGICA DOS FORMULÁRIOS: Um JSON dinâmico que vai guardar os atributos de engenharia (custo, material, diâmetro da tubulação)
  attributes   Json      @default("{}")  
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  geomWkt      String?   
  srid         Int       @default(4326) 

  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  projectId    String?
  project      Project?  @relation(fields: [projectId], references: [id])
  logs         AssetLog[]

  @@index([tenantId])
  @@index([projectId])
  @@index([type])
  @@map("assets")
}

model AssetLog {
  id          String   @id @default(cuid())
  note        String
  photos      String[]
  lat         Float?
  lng         Float?
  createdAt   DateTime @default(now())

  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@index([assetId])
  @@map("asset_logs")
}

model Invoice {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(12, 2)
  status      InvoiceStatus @default(PENDENTE)
  dueDate     DateTime
  paidAt      DateTime?
  createdAt   DateTime      @default(now())

  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

model UserSession {
  id          String   @id @default(cuid())
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}