// UrbanDesk Prisma schema
// Database: PostgreSQL + PostGIS

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

enum TenantStatus {
  TRIAL
  ATIVO
  INADIMPLENTE
  CANCELADO
}

enum TenantPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum UserRole {
  SUPERADMIN
  SECRETARIO
  ENGENHEIRO
  CAMPO
}

enum ProjectStatus {
  PLANEJADO
  EM_ANDAMENTO
  PARALISADO
  CONCLUIDO
  CANCELADO
}

enum ProjectType {
  OBRA
  SERVICO_ENGENHARIA
  MANUTENCAO
  ESTUDO_PROJETO
  FISCALIZACAO
  LICITACAO
  PLANO_SETORIAL
  REGULARIZACAO
}

enum ProjectPriority {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum ProjectCriticality {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

enum ProjectOperationalStatus {
  CADASTRADO
  EM_ESTUDO
  EM_LICITACAO
  CONTRATADO
  EM_EXECUCAO
  EM_MEDICAO
  PARALISADO
  EM_RECEBIMENTO
  ENCERRADO
  CANCELADO
}

enum ProjectVisibility {
  INTERNO
  PUBLICO_RESUMIDO
  PUBLICO_INTEGRAL
}

enum ProjectTechnicalArea {
  DRENAGEM
  PAVIMENTACAO
  ILUMINACAO
  ARBORIZACAO
  SINALIZACAO
  FISCALIZACAO
  MOBILIDADE
  SANEAMENTO
  EDIFICACOES
  ZELADORIA
}

enum ProjectContractStatus {
  MINUTA
  VIGENTE
  ADITIVADO
  SUSPENSO
  ENCERRADO
  RESCINDIDO
}

enum ProjectFundingSourceType {
  TESOURO
  CONVENIO
  OPERACAO_CREDITO
  FINANCIAMENTO
  EMENDA
  FUNDO
  PARCERIA
  OUTRO
}

enum ProjectFundingSourceStatus {
  PLANEJADA
  ASSEGURADA
  LIBERADA
  BLOQUEADA
  ENCERRADA
}

enum ProjectPhaseStatus {
  PLANEJADA
  PRONTA
  EM_EXECUCAO
  BLOQUEADA
  CONCLUIDA
  CANCELADA
}

enum ProjectMilestoneStatus {
  PLANEJADO
  EM_RISCO
  CONCLUIDO
  ATRASADO
  CANCELADO
}

enum ProjectDocumentType {
  TERMO_REFERENCIA
  PROJETO_BASICO
  PROJETO_EXECUTIVO
  MEMORIAL
  ORCAMENTO
  CRONOGRAMA
  LICITACAO
  CONTRATO
  ADITIVO
  MEDICAO
  RELATORIO
  LICENCA
  MAPA
  FOTO
  OUTRO
}

enum ProjectMeasurementStatus {
  RASCUNHO
  SUBMETIDA
  APROVADA
  REJEITADA
  PAGA
}

enum ProjectInspectionType {
  ROTINA
  MEDICAO
  QUALIDADE
  SEGURANCA
  RECEBIMENTO
  EXTRAORDINARIA
}

enum ProjectInspectionStatus {
  AGENDADA
  REALIZADA
  CANCELADA
}

enum ProjectIssueType {
  BLOQUEIO
  NAO_CONFORMIDADE
  SEGURANCA
  AMBIENTAL
  PRAZO
  FINANCEIRO
  DOCUMENTAL
  COMUNITARIO
  TECNICO
  OUTRO
}

enum ProjectIssueStatus {
  ABERTA
  EM_TRATATIVA
  RESOLVIDA
  FECHADA
  CANCELADA
}

enum ProjectRiskCategory {
  PRAZO
  FINANCEIRO
  TECNICO
  AMBIENTAL
  JURIDICO
  OPERACIONAL
  SOCIAL
  SEGURANCA
  CLIMATICO
  OUTRO
}

enum ProjectRiskStatus {
  IDENTIFICADO
  MONITORANDO
  MITIGADO
  MATERIALIZADO
  ENCERRADO
}

enum ProjectRiskProbability {
  BAIXA
  MEDIA
  ALTA
}

enum ProjectRiskImpact {
  BAIXO
  MEDIO
  ALTO
  CRITICO
}

enum AssetType {
  PONTO
  TRECHO
  AREA
}

enum InfrastructureLayerCode {
  PONNOT
  PONT_ILUM
}

enum InfrastructureLayerStatus {
  PROCESSING
  READY
  FAILED
}

enum InfrastructureLayerUploadStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum InfrastructureLayerUploadFileRole {
  ZIP_ARCHIVE
  SHP
  SHX
  DBF
  PRJ
  CPG
}

enum InvoiceStatus {
  PENDENTE
  PAGO
  VENCIDO
  CANCELADO
}

model Tenant {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  cnpj        String       @unique
  state       String       @db.Char(2)
  plan        TenantPlan   @default(STARTER)
  status      TenantStatus @default(TRIAL)
  mrr         Decimal      @default(0) @db.Decimal(12, 2)
  trialEndsAt DateTime?
  logoUrl     String?
  mapLat      Float?
  mapLng      Float?
  mapZoom     Float?       @default(12)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users                           User[]
  projects                        Project[]
  projectContracts                ProjectContract[]
  projectFundingSources           ProjectFundingSource[]
  projectPhases                   ProjectPhase[]
  projectMilestones               ProjectMilestone[]
  projectDocuments                ProjectDocument[]
  projectMeasurements             ProjectMeasurement[]
  projectInspections              ProjectInspection[]
  projectIssues                   ProjectIssue[]
  projectRisks                    ProjectRisk[]
  projectComments                 ProjectComment[]
  assets                          Asset[]
  invoices                        Invoice[]
  baseLayers                      BaseLayer[]
  ownedInfrastructureLayers       InfrastructureLayer[]                   @relation("InfrastructureLayerOwner")
  infrastructureLayers            InfrastructureLayerTenantAccess[]
  infrastructureLayerUploads      InfrastructureLayerUpload[]             @relation("InfrastructureLayerUploadOwner")
  infrastructureLayerUploadAccess InfrastructureLayerUploadTenantAccess[]
  auditLogs                       AuditLog[]

  @@map("tenants")
}

model BaseLayer {
  id          String   @id @default(cuid())
  name        String
  type        String
  geoJsonData Json
  tenantId    String
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("base_layers")
}

model InfrastructureLayer {
  id                       String                    @id @default(cuid())
  code                     InfrastructureLayerCode
  name                     String
  description              String?
  status                   InfrastructureLayerStatus @default(PROCESSING)
  ownerTenantId            String?
  sourceArchiveName        String
  sourceArchiveKey         String
  sourceArchiveUrl         String?
  sourceArchiveSecureUrl   String?
  sourceArchiveExpiresAt   DateTime?
  sourceArchiveContentType String?
  sourceDatasetName        String?
  originalCrs              String?
  geometryType             String?
  featureCount             Int                       @default(0)
  bbox                     Json?
  geoJsonData              Json
  metadata                 Json                      @default("{}")
  uploadedById             String
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt

  ownerTenant       Tenant?                           @relation("InfrastructureLayerOwner", fields: [ownerTenantId], references: [id], onDelete: SetNull)
  uploadedBy        User                              @relation("InfrastructureLayerUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  sourceUpload      InfrastructureLayerUpload?        @relation("InfrastructureLayerFinalLayer")
  authorizedTenants InfrastructureLayerTenantAccess[]

  @@index([ownerTenantId, code, status])
  @@index([code, status, createdAt])
  @@index([uploadedById, createdAt])
  @@map("infrastructure_layers")
}

model InfrastructureLayerTenantAccess {
  infrastructureLayerId String
  tenantId              String
  createdAt             DateTime @default(now())

  infrastructureLayer InfrastructureLayer @relation(fields: [infrastructureLayerId], references: [id], onDelete: Cascade)
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([infrastructureLayerId, tenantId])
  @@index([tenantId, createdAt])
  @@map("infrastructure_layer_tenant_access")
}

model InfrastructureLayerUpload {
  id               String                          @id @default(cuid())
  code             InfrastructureLayerCode
  status           InfrastructureLayerUploadStatus @default(UPLOADED)
  ownerTenantId    String?
  uploadMetadata   Json                            @default("{}")
  processingResult Json?
  processingError  String?
  uploadedById     String
  uploadedAt       DateTime                        @default(now())
  processedAt      DateTime?
  finalLayerId     String?                         @unique
  createdAt        DateTime                        @default(now())
  updatedAt        DateTime                        @updatedAt

  ownerTenant       Tenant?                                 @relation("InfrastructureLayerUploadOwner", fields: [ownerTenantId], references: [id], onDelete: SetNull)
  uploadedBy        User                                    @relation("InfrastructureLayerUploadSender", fields: [uploadedById], references: [id], onDelete: Cascade)
  finalLayer        InfrastructureLayer?                    @relation("InfrastructureLayerFinalLayer", fields: [finalLayerId], references: [id], onDelete: SetNull)
  files             InfrastructureLayerUploadFile[]
  authorizedTenants InfrastructureLayerUploadTenantAccess[]

  @@index([code, status, uploadedAt])
  @@index([ownerTenantId, uploadedAt])
  @@index([uploadedById, uploadedAt])
  @@map("infrastructure_layer_uploads")
}

model InfrastructureLayerUploadFile {
  id                 String                            @id @default(cuid())
  uploadId           String
  role               InfrastructureLayerUploadFileRole
  originalName       String
  archiveEntryName   String?
  storageKey         String?
  storageUrl         String?
  secureUrl          String?
  secureUrlExpiresAt DateTime?
  contentType        String?
  fileSize           Int?
  metadata           Json                              @default("{}")
  createdAt          DateTime                          @default(now())

  upload InfrastructureLayerUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([uploadId, role])
  @@map("infrastructure_layer_upload_files")
}

model InfrastructureLayerUploadTenantAccess {
  uploadId  String
  tenantId  String
  createdAt DateTime @default(now())

  upload InfrastructureLayerUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  tenant Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([uploadId, tenantId])
  @@index([tenantId, createdAt])
  @@map("infrastructure_layer_upload_tenant_access")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(CAMPO)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String?

  tenant                             Tenant?                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetLogs                          AssetLog[]
  sessions                           UserSession[]
  auditLogs                          AuditLog[]
  uploadedInfrastructureLayers       InfrastructureLayer[]       @relation("InfrastructureLayerUploader")
  uploadedInfrastructureLayerUploads InfrastructureLayerUpload[] @relation("InfrastructureLayerUploadSender")
  managedProjects                    Project[]                   @relation("ProjectManager")
  inspectedProjects                  Project[]                   @relation("ProjectInspector")
  phaseOwnerships                    ProjectPhase[]              @relation("ProjectPhaseOwner")
  milestoneResponsibilities          ProjectMilestone[]          @relation("ProjectMilestoneResponsible")
  uploadedProjectDocuments           ProjectDocument[]           @relation("ProjectDocumentUploader")
  projectMeasurementsTaken           ProjectMeasurement[]        @relation("ProjectMeasurementMeasuredBy")
  projectMeasurementsApproved        ProjectMeasurement[]        @relation("ProjectMeasurementApprovedBy")
  projectInspectionsLed              ProjectInspection[]         @relation("ProjectInspectionInspector")
  projectIssuesReported              ProjectIssue[]              @relation("ProjectIssueReportedBy")
  projectIssuesAssigned              ProjectIssue[]              @relation("ProjectIssueAssignedTo")
  projectRiskOwnerships              ProjectRisk[]               @relation("ProjectRiskOwner")
  projectCommentsAuthored            ProjectComment[]            @relation("ProjectCommentAuthor")

  @@index([tenantId])
  @@map("users")
}

model Project {
  id                    String                   @id @default(cuid())
  code                  String?
  name                  String
  description           String?
  projectType           ProjectType?
  responsibleDepartment String?
  responsibleArea       String?
  technicalAreas        ProjectTechnicalArea[]   @default([])
  neighborhood          String?
  district              String?
  region                String?
  priority              ProjectPriority          @default(MEDIA)
  criticality           ProjectCriticality       @default(MEDIA)
  status                ProjectStatus            @default(PLANEJADO)
  operationalStatus     ProjectOperationalStatus @default(CADASTRADO)
  publicVisibility      ProjectVisibility        @default(INTERNO)
  budget                Decimal?                 @db.Decimal(15, 2)
  estimatedBudget       Decimal?                 @db.Decimal(15, 2)
  contractedBudget      Decimal?                 @db.Decimal(15, 2)
  measuredBudget        Decimal?                 @db.Decimal(15, 2)
  paidBudget            Decimal?                 @db.Decimal(15, 2)
  startDate             DateTime?
  endDate               DateTime?
  plannedStartDate      DateTime?
  plannedEndDate        DateTime?
  actualStartDate       DateTime?
  actualEndDate         DateTime?
  completionPct         Int                      @default(0)
  physicalProgressPct   Int                      @default(0)
  financialProgressPct  Int                      @default(0)
  managerId             String?
  inspectorId           String?
  contractorName        String?
  address               String?
  referencePoint        String?
  procurementProcess    String?
  procurementModality   String?
  contractNumber        String?
  metadata              Json                     @default("{}")
  geomWkt               String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  tenantId              String

  tenant         Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager        User?                  @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)
  inspector      User?                  @relation("ProjectInspector", fields: [inspectorId], references: [id], onDelete: SetNull)
  contracts      ProjectContract[]
  fundingSources ProjectFundingSource[]
  phases         ProjectPhase[]
  milestones     ProjectMilestone[]
  documents      ProjectDocument[]
  measurements   ProjectMeasurement[]
  inspections    ProjectInspection[]
  issues         ProjectIssue[]
  risks          ProjectRisk[]
  comments       ProjectComment[]
  assets         Asset[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@index([tenantId, projectType])
  @@index([tenantId, operationalStatus])
  @@index([tenantId, publicVisibility])
  @@index([managerId])
  @@index([inspectorId])
  @@map("projects")
}

model Asset {
  id          String    @id @default(cuid())
  name        String
  type        AssetType
  description String?
  photos      String[]
  attributes  Json      @default("{}")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  geomWkt     String?
  srid        Int       @default(4326)
  tenantId    String
  projectId   String?

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project?       @relation(fields: [projectId], references: [id])
  issues  ProjectIssue[]
  logs    AssetLog[]

  @@index([tenantId])
  @@index([projectId])
  @@index([type])
  @@map("assets")
}

model ProjectContract {
  id                  String                @id @default(cuid())
  contractNumber      String?
  title               String
  description         String?
  contractorName      String?
  contractorTaxId     String?
  procurementProcess  String?
  procurementModality String?
  signedAt            DateTime?
  startDate           DateTime?
  endDate             DateTime?
  status              ProjectContractStatus @default(MINUTA)
  contractedAmount    Decimal?              @db.Decimal(15, 2)
  additiveAmount      Decimal?              @db.Decimal(15, 2)
  measuredAmount      Decimal?              @db.Decimal(15, 2)
  paidAmount          Decimal?              @db.Decimal(15, 2)
  notes               String?
  metadata            Json                  @default("{}")
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  tenantId            String
  projectId           String

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documents    ProjectDocument[]
  measurements ProjectMeasurement[]
  comments     ProjectComment[]

  @@unique([tenantId, contractNumber])
  @@index([tenantId, projectId])
  @@index([projectId, status])
  @@map("project_contracts")
}

model ProjectFundingSource {
  id                String                     @id @default(cuid())
  sourceName        String
  sourceType        ProjectFundingSourceType
  status            ProjectFundingSourceStatus @default(PLANEJADA)
  budgetCode        String?
  externalReference String?
  plannedAmount     Decimal?                   @db.Decimal(15, 2)
  committedAmount   Decimal?                   @db.Decimal(15, 2)
  releasedAmount    Decimal?                   @db.Decimal(15, 2)
  usedAmount        Decimal?                   @db.Decimal(15, 2)
  startDate         DateTime?
  endDate           DateTime?
  isPrimary         Boolean                    @default(false)
  metadata          Json                       @default("{}")
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  tenantId          String
  projectId         String

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId, projectId])
  @@index([projectId, sourceType])
  @@index([projectId, status])
  @@map("project_funding_sources")
}

model ProjectPhase {
  id                   String                @id @default(cuid())
  code                 String?
  name                 String
  description          String?
  technicalArea        ProjectTechnicalArea?
  sequence             Int
  status               ProjectPhaseStatus    @default(PLANEJADA)
  plannedStartDate     DateTime?
  plannedEndDate       DateTime?
  actualStartDate      DateTime?
  actualEndDate        DateTime?
  physicalProgressPct  Int                   @default(0)
  financialProgressPct Int                   @default(0)
  ownerId              String?
  metadata             Json                  @default("{}")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  tenantId             String
  projectId            String

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project      Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner        User?                @relation("ProjectPhaseOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  milestones   ProjectMilestone[]
  documents    ProjectDocument[]
  measurements ProjectMeasurement[]
  inspections  ProjectInspection[]
  issues       ProjectIssue[]
  risks        ProjectRisk[]
  comments     ProjectComment[]

  @@unique([projectId, sequence])
  @@unique([projectId, code])
  @@index([tenantId, projectId])
  @@index([projectId, status])
  @@index([ownerId])
  @@map("project_phases")
}

model ProjectMilestone {
  id                String                 @id @default(cuid())
  title             String
  description       String?
  status            ProjectMilestoneStatus @default(PLANEJADO)
  targetDate        DateTime?
  completedAt       DateTime?
  responsibleUserId String?
  metadata          Json                   @default("{}")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  tenantId          String
  projectId         String
  phaseId           String?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase           ProjectPhase?    @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  responsibleUser User?            @relation("ProjectMilestoneResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)
  comments        ProjectComment[]

  @@index([tenantId, projectId])
  @@index([projectId, status])
  @@index([phaseId, targetDate])
  @@index([responsibleUserId])
  @@map("project_milestones")
}

model ProjectDocument {
  id            String              @id @default(cuid())
  title         String
  description   String?
  documentType  ProjectDocumentType @default(OUTRO)
  fileName      String
  storageKey    String
  fileUrl       String?
  mimeType      String?
  fileSize      Int?
  documentDate  DateTime?
  isPublic      Boolean             @default(false)
  metadata      Json                @default("{}")
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  tenantId      String
  projectId     String
  phaseId       String?
  contractId    String?
  measurementId String?
  inspectionId  String?
  uploadedById  String?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       ProjectPhase?       @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  contract    ProjectContract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)
  measurement ProjectMeasurement? @relation(fields: [measurementId], references: [id], onDelete: SetNull)
  inspection  ProjectInspection?  @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  uploadedBy  User?               @relation("ProjectDocumentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId])
  @@index([projectId, documentType])
  @@index([tenantId, isPublic])
  @@index([phaseId])
  @@index([contractId])
  @@index([measurementId])
  @@index([inspectionId])
  @@index([uploadedById])
  @@map("project_documents")
}

model ProjectMeasurement {
  id                   String                   @id @default(cuid())
  measurementNumber    Int
  referenceMonth       DateTime?
  periodStart          DateTime?
  periodEnd            DateTime?
  measuredAt           DateTime?
  status               ProjectMeasurementStatus @default(RASCUNHO)
  physicalProgressPct  Int                      @default(0)
  financialProgressPct Int                      @default(0)
  measuredAmount       Decimal?                 @db.Decimal(15, 2)
  approvedAmount       Decimal?                 @db.Decimal(15, 2)
  paidAmount           Decimal?                 @db.Decimal(15, 2)
  notes                String?
  metadata             Json                     @default("{}")
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  tenantId             String
  projectId            String
  phaseId              String?
  contractId           String?
  measuredById         String?
  approvedById         String?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       ProjectPhase?       @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  contract    ProjectContract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)
  measuredBy  User?               @relation("ProjectMeasurementMeasuredBy", fields: [measuredById], references: [id], onDelete: SetNull)
  approvedBy  User?               @relation("ProjectMeasurementApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  documents   ProjectDocument[]
  inspections ProjectInspection[]
  comments    ProjectComment[]

  @@unique([projectId, measurementNumber])
  @@index([tenantId, projectId])
  @@index([projectId, status])
  @@index([contractId])
  @@index([phaseId])
  @@index([measuredById])
  @@index([approvedById])
  @@map("project_measurements")
}

model ProjectInspection {
  id              String                  @id @default(cuid())
  inspectionType  ProjectInspectionType   @default(ROTINA)
  status          ProjectInspectionStatus @default(AGENDADA)
  scheduledAt     DateTime?
  occurredAt      DateTime?
  location        String?
  summary         String?
  findings        String?
  recommendations String?
  metadata        Json                    @default("{}")
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  tenantId        String
  projectId       String
  phaseId         String?
  measurementId   String?
  inspectorId     String?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase       ProjectPhase?       @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  measurement ProjectMeasurement? @relation(fields: [measurementId], references: [id], onDelete: SetNull)
  inspector   User?               @relation("ProjectInspectionInspector", fields: [inspectorId], references: [id], onDelete: SetNull)
  documents   ProjectDocument[]
  issues      ProjectIssue[]
  comments    ProjectComment[]

  @@index([tenantId, projectId])
  @@index([projectId, status])
  @@index([projectId, inspectionType])
  @@index([phaseId])
  @@index([measurementId])
  @@index([inspectorId, occurredAt])
  @@map("project_inspections")
}

model ProjectIssue {
  id              String             @id @default(cuid())
  title           String
  description     String?
  issueType       ProjectIssueType   @default(OUTRO)
  status          ProjectIssueStatus @default(ABERTA)
  priority        ProjectPriority    @default(MEDIA)
  dueDate         DateTime?
  resolvedAt      DateTime?
  resolutionNotes String?
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenantId        String
  projectId       String
  phaseId         String?
  inspectionId    String?
  assetId         String?
  reportedById    String?
  assignedToId    String?

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase      ProjectPhase?      @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  inspection ProjectInspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  asset      Asset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  reportedBy User?              @relation("ProjectIssueReportedBy", fields: [reportedById], references: [id], onDelete: SetNull)
  assignedTo User?              @relation("ProjectIssueAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  comments   ProjectComment[]

  @@index([tenantId, projectId])
  @@index([projectId, status])
  @@index([projectId, priority])
  @@index([phaseId])
  @@index([inspectionId])
  @@index([assetId])
  @@index([reportedById])
  @@index([assignedToId])
  @@map("project_issues")
}

model ProjectRisk {
  id              String                 @id @default(cuid())
  title           String
  description     String?
  category        ProjectRiskCategory    @default(OUTRO)
  status          ProjectRiskStatus      @default(IDENTIFICADO)
  probability     ProjectRiskProbability @default(MEDIA)
  impact          ProjectRiskImpact      @default(MEDIO)
  mitigationPlan  String?
  contingencyPlan String?
  reviewDate      DateTime?
  metadata        Json                   @default("{}")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  tenantId        String
  projectId       String
  phaseId         String?
  ownerId         String?

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phase    ProjectPhase?    @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  owner    User?            @relation("ProjectRiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  comments ProjectComment[]

  @@index([tenantId, projectId])
  @@index([projectId, status])
  @@index([projectId, category])
  @@index([phaseId])
  @@index([ownerId])
  @@map("project_risks")
}

model ProjectComment {
  id            String   @id @default(cuid())
  body          String
  isInternal    Boolean  @default(true)
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenantId      String
  projectId     String
  authorId      String?
  phaseId       String?
  contractId    String?
  milestoneId   String?
  measurementId String?
  inspectionId  String?
  issueId       String?
  riskId        String?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User?               @relation("ProjectCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  phase       ProjectPhase?       @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  contract    ProjectContract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)
  milestone   ProjectMilestone?   @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  measurement ProjectMeasurement? @relation(fields: [measurementId], references: [id], onDelete: SetNull)
  inspection  ProjectInspection?  @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  issue       ProjectIssue?       @relation(fields: [issueId], references: [id], onDelete: SetNull)
  risk        ProjectRisk?        @relation(fields: [riskId], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId, createdAt])
  @@index([authorId, createdAt])
  @@index([phaseId])
  @@index([contractId])
  @@index([milestoneId])
  @@index([measurementId])
  @@index([inspectionId])
  @@index([issueId])
  @@index([riskId])
  @@map("project_comments")
}

model AssetLog {
  id        String   @id @default(cuid())
  note      String
  photos    String[]
  lat       Float?
  lng       Float?
  createdAt DateTime @default(now())
  assetId   String
  userId    String

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@index([assetId])
  @@map("asset_logs")
}

model Invoice {
  id        String        @id @default(cuid())
  amount    Decimal       @db.Decimal(12, 2)
  status    InvoiceStatus @default(PENDENTE)
  dueDate   DateTime
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  tenantId  String

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@map("invoices")
}

model UserSession {
  id        String   @id @default(cuid())
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  entityType String?
  entityId   String?
  userId     String?
  userName   String?
  userEmail  String?
  userRole   String?
  tenantId   String?
  ip         String?
  userAgent  String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}
